{
  "name": "spendify",
  "version": "1.0.0",
  "description": "Smart Spending. Clear Insights. - A modern personal finance dashboard",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node --import ./server/instrument.js server/server.js",
    "dev": "node --watch --import ./server/instrument.js server/server.js",
    "client": "cd client && npx serve -s .",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "verify:indexes": "node server/scripts/verifyIndexes.js",
    "sync:indexes": "node server/scripts/syncIndexes.js",
    "sentry:release": "sentry-cli releases new -p spendify $npm_package_version && sentry-cli releases set-commits --auto $npm_package_version && sentry-cli releases finalize $npm_package_version",
    "postinstall": "node server/scripts/setupEnv.js"
  },
  "keywords": [
    "finance",
    "dashboard",
    "expense-tracker",
    "personal-finance"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.1",
    "morgan": "^1.10.0",
    "redis": "^5.11.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
